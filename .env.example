# =============================================================================
# 公共环境变量样板
# 真实值请复制为 .env 或部署 deploy/fc/prod.env，不提交到 git。
# =============================================================================

# ---- 应用基础 ----
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
PUBLIC_APP_DOMAIN=localhost
APP_LOG_LEVEL=info

# ---- 数据库 ----
# 本地可直接使用 DATABASE_URL；FC/CI 推荐使用拆分变量，通过 VPC 内网访问。
DATABASE_URL=postgres://yishan_tan_app:change_me_in_production@localhost:5432/yishan_tan
DATABASE_USER=yishan_tan_app
DATABASE_PASSWORD=change_me_in_production
DATABASE_NAME=yishan_tan
DATABASE_HOST=localhost
DATABASE_PORT=5432

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- 认证 (better-auth) ----
BETTER_AUTH_SECRET=replace-with-strong-random-secret
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000
