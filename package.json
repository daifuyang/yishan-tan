{
  "name": "yishan-tan",
  "version": "0.1.0",
  "private": true,
  "description": "Yishan Tan 企业级 TanStack Start 底座",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite dev --host 0.0.0.0",
    "build": "NODE_ENV=production vite build",
    "start": "node .output/server/index.mjs",
    "build:fc": "node scripts/build-fc.mjs",
    "deploy": "bash scripts/deploy-fc.sh apply",
    "deploy:plan": "bash scripts/deploy-fc.sh plan",
    "deploy:smoke": "bash scripts/deploy-fc.sh smoke",
    "deploy:rollback": "bash scripts/deploy-fc.sh rollback",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:check": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx db/seed.ts",
    "db:reset": "drizzle-kit drop && pnpm db:migrate && pnpm db:seed",
    "arch:check": "node scripts/arch/check-all.mjs",
    "arch:check:routes": "node scripts/arch/check-routes.mjs",
    "arch:check:actions": "node scripts/arch/check-actions.mjs",
    "arch:check:services": "node scripts/arch/check-services.mjs",
    "arch:check:naming": "node scripts/arch/check-naming.mjs",
    "gen:resource": "tsx scripts/generators/gen-resource.ts"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.6.22",
    "@radix-ui/react-slot": "^1.3.0",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-router": "^1.95.0",
    "@tanstack/react-start": "^1.95.0",
    "better-auth": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.0",
    "ioredis": "^5.4.1",
    "isbot": "^5.1.17",
    "lucide-react": "^0.460.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "drizzle-kit": "^0.31.4",
    "nitro": "3.0.260610-beta",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^7.0.0",
    "vite-tsconfig-paths": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "@parcel/watcher", "esbuild"]
  }
}
