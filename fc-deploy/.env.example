# fc-deploy 环境变量示例
# 复制为 prod.env 后填写真实值，不提交到 git。

# ---- 阿里云 / FC 网络 ----
VPC_ID=
VSWITCH_ID=
SECURITY_GROUP_ID=

# ---- 应用 ----
PUBLIC_APP_URL=https://example.zerocmf.com
BETTER_AUTH_URL=https://example.zerocmf.com
BETTER_AUTH_TRUSTED_ORIGINS=https://example.zerocmf.com,https://cn-shanghai.fcapp.run
BETTER_AUTH_SECRET=replace-with-strong-random-secret

# ---- 数据 ----
DATABASE_URL=postgres://zerocmf:replace_me@host:5432/zerocmf_platform
REDIS_URL=redis://:replace_me@host:6379/0
