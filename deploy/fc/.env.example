# deploy/fc 环境变量示例
# 复制为 prod.env 后填写真实值，不提交到 git。

# ---- 阿里云 / FC 网络 ----
VPC_ID=
VSWITCH_ID=
SECURITY_GROUP_ID=

# ---- 应用 ----
PUBLIC_APP_DOMAIN=tan.zerocmf.com
PUBLIC_APP_URL=https://tan.zerocmf.com
BETTER_AUTH_URL=https://tan.zerocmf.com
BETTER_AUTH_TRUSTED_ORIGINS=https://tan.zerocmf.com,https://cn-shanghai.fcapp.run
BETTER_AUTH_SECRET=replace-with-strong-random-secret
SYSTEM_ADMIN_IDS=

# ---- 数据 ----
DATABASE_USER=yishan_tan_app
DATABASE_PASSWORD=replace_me
DATABASE_NAME=yishan_tan
DATABASE_HOST=172.23.212.135
DATABASE_PORT=5432
REDIS_URL=redis://:replace_me@host:6379/0
