#!/usr/bin/env bash
#
# FC custom runtime 启动脚本（custom.debian12）。
# - 镜像自带 node-22，路径已通过 s.yaml 的 PATH 环境变量 (/var/fc/lang/nodejs22/bin) 暴露。
# - 期望 build-fc.mjs 用 Nitro 模式产出于 .output/server/index.mjs（rollup 已内联全部 deps）。
# - 只负责启动应用，禁止执行 apt-get / pnpm install / 数据库迁移 / 证书续签。

set -euo pipefail

cd /code

export NODE_ENV="${NODE_ENV:-production}"
export PORT="${PORT:-9000}"

if ! command -v node >/dev/null 2>&1; then
  echo "[bootstrap] node binary not found (expected via PATH=/var/fc/lang/nodejs22/bin)" >&2
  exit 1
fi

if [[ ! -f /code/.output/server/index.mjs ]]; then
  echo "[bootstrap] .output/server/index.mjs not found (build-fc must emit Nitro output)" >&2
  exit 1
fi

echo "[bootstrap] starting node .output/server/index.mjs (NODE_ENV=${NODE_ENV}, PORT=${PORT})"
exec node .output/server/index.mjs
