#!/usr/bin/env bash
#
# FC custom runtime 启动脚本 — 仅用于 yishan-tan-migrator 函数。
# - 镜像自带 node-22（s.yaml 的 PATH=/var/fc/lang/nodejs22/bin 暴露）。
# - build:fc 已经把 esbuild 打包好的 migrate.mjs 与 db/migrations 一起塞进 code/。
# - migrate.mjs 退出时函数实例自然结束（FC 调度上 sync invocation 等待 bootstrap 退出）。
#
# 注意：本脚本不应在 app 函数中使用；保持 app 函数启动器简单（见 bootstrap）。

set -euo pipefail

cd /code

export NODE_ENV="${NODE_ENV:-production}"
# migrationsFolder 在 s.yaml 的 environmentVariables 注入；默认 /code/db/migrations
export MIGRATIONS_FOLDER="${MIGRATIONS_FOLDER:-/code/db/migrations}"

if ! command -v node >/dev/null 2>&1; then
  echo "[migrator-bootstrap] node binary not found (expected via PATH=/var/fc/lang/nodejs22/bin)" >&2
  exit 1
fi

if [[ ! -f /code/migrate.mjs ]]; then
  echo "[migrator-bootstrap] /code/migrate.mjs missing — build-fc.mjs may have failed to bundle" >&2
  exit 1
fi

if [[ ! -d "${MIGRATIONS_FOLDER}" ]]; then
  echo "[migrator-bootstrap] ${MIGRATIONS_FOLDER} not found — db/migrations/ not staged" >&2
  exit 1
fi

echo "[migrator-bootstrap] launching migrate.mjs (MIGRATIONS_FOLDER=${MIGRATIONS_FOLDER})"
exec node /code/migrate.mjs
