{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "ignoreUnknown": true,
    "ignore": [
      "node_modules",
      ".output",
      "dist",
      "fc-deploy/code",
      "**/routeTree.gen.ts",
      "db/migrations",
      "openapi.generated.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "recommended": true
      },
      "correctness": {
        "useExhaustiveDependencies": "warn",
        "noUnusedImports": "error",
        "noUnusedVariables": "error"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noConsole": "warn"
      },
      "style": {
        "useImportType": "warn",
        "useConsistentArrayType": "error"
      }
    }
  },
  "javascript": {
    "jsxRuntime": "transparent"
  },
  "overrides": [
    {
      "include": ["scripts/**", "db/seed.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    }
  ]
}
